{
  "version": 1,
  "apps": [
    {
      "id": "discord",
      "name": "Discord",
      "category": "deb",
      "source_type": "static_url",
      "description": "Voice, video, and text chat.",
      "url": "https://discord.com/api/download?platform=linux&format=deb",
      "version_regex": "discord-([0-9.]+)\\.deb",
      "package_name": "discord"
    },
    {
      "id": "opentabletdriver",
      "name": "OpenTabletDriver",
      "category": "deb",
      "source_type": "github_release",
      "description": "Open source, cross-platform tablet driver.",
      "github_owner": "OpenTabletDriver",
      "github_repo": "OpenTabletDriver",
      "asset_pattern": "x64\\.deb$",
      "package_name": "opentabletdriver"
    },
    {
      "id": "godot-standard",
      "name": "Godot (Standard)",
      "category": "archive",
      "source_type": "github_release",
      "description": "2D/3D game engine - standard build, no C# support.",
      "github_owner": "godotengine",
      "github_repo": "godot",
      "asset_pattern": "Godot_v[0-9.]+-stable_linux\\.x86_64\\.zip$",
      "archive_subdir_name": "Godot",
      "archive_executable_pattern": "^Godot_v[0-9.]+-stable_linux\\.x86_64$",
      "archive_symlink_name": "godot"
    },
    {
      "id": "godot-mono",
      "name": "Godot (.NET/Mono)",
      "category": "archive",
      "source_type": "github_release",
      "description": "2D/3D game engine - .NET build with C# support.",
      "github_owner": "godotengine",
      "github_repo": "godot",
      "asset_pattern": "Godot_v[0-9.]+-stable_mono_linux_x86_64\\.zip$",
      "archive_subdir_name": "Godot-Mono",
      "archive_executable_pattern": "^Godot_v[0-9.]+-stable_mono_linux\\.x86_64$",
      "archive_symlink_name": "godot-mono"
    },
    {
      "id": "openrgb",
      "name": "OpenRGB",
      "description": "Open source RGB lighting control that doesn't depend on manufacturer software.",
      "source_type": "gitea_release",
      "gitea_host": "codeberg.org",
      "gitea_owner": "OpenRGB",
      "gitea_repo": "OpenRGB",
      "variants": [
        {
          "category": "deb",
          "asset_pattern": "^openrgb_.*_amd64_bookworm_[0-9a-f]+\\.deb$",
          "package_name": "openrgb"
        },
        {
          "category": "appimage",
          "asset_pattern": "^OpenRGB_.*_x86_64_[0-9a-f]+\\.AppImage$"
        }
      ]
    },
    {
      "id": "appify",
      "name": "Appify",
      "description": "Turn websites into native-feeling PWAs on Linux using your existing browser engines.",
      "source_type": "github_release",
      "github_owner": "bobbycomet",
      "github_repo": "Appify",
      "variants": [
        {
          "category": "deb",
          "asset_pattern": "^appify-[0-9.]+-[0-9]+\\.deb$",
          "package_name": "appify"
        },
        {
          "category": "appimage",
          "asset_pattern": "^Appify-x86_64\\.AppImage$"
        }
      ]
    },
    {
      "id": "fan-hub",
      "name": "Fan Hub",
      "description": "GUI fan and RGB control.",
      "source_type": "github_release",
      "github_owner": "bobbycomet",
      "github_repo": "Fan-Hub",
      "variants": [
        {
          "category": "deb",
          "asset_pattern": "^fanhub_[0-9.]+_amd64\\.deb$",
          "package_name": "fanhub"
        },
        {
          "category": "appimage",
          "asset_pattern": "^FanHub-[0-9.]+-x86_64\\.AppImage$"
        }
      ]
    }
  ]
}
